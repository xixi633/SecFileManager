<template>
  <div class="login-container">
    <div class="login-box">
      <div class="login-header">
        <div class="logo-icon">
          <el-icon :size="40" color="#409EFF"><Files /></el-icon>
        </div>
        <h2>е®үе…Ёж–Үд»¶з®ЎзҗҶзі»з»ҹ</h2>
        <p class="subtitle">Secure File Management System</p>
      </div>

      <el-card class="login-card" shadow="hover">
        <el-tabs v-model="activeTab" class="custom-tabs" stretch>
          <el-tab-pane label="з”ЁжҲ·зҷ»еҪ•" name="login">
            <el-form :model="loginForm" class="login-form" size="large" @submit.prevent>
              <el-form-item>
                <el-input 
                  v-model="loginForm.username" 
                  placeholder="иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚ" 
                  :prefix-icon="User"
                />
              </el-form-item>
              <el-form-item>
                <el-input
                  v-model="loginForm.password"
                  type="password"
                  placeholder="иҜ·иҫ“е…ҘеҜҶз ?
                  :prefix-icon="Lock"
                  show-password
                  @keyup.enter="onLogin"
                />
              </el-form-item>
              <div class="forgot-row">
                <el-button link type="primary" @click="openForgot">еҝҳи®°еҜҶз Ғпј?/el-button>
              </div>
              <div class="form-actions">
                <el-button 
                  type="primary" 
                  :loading="loading" 
                  class="action-btn"
                  @click="onLogin"
                >
                  зҷ?еҪ?
                </el-button>
              </div>
            </el-form>
          </el-tab-pane>
          
          <el-tab-pane label="жіЁеҶҢиҙҰеҸ·" name="register">
            <el-form :model="registerForm" class="login-form" size="large" @submit.prevent>
              <el-form-item>
                <el-input 
                  v-model="registerForm.username" 
                  placeholder="и®ҫзҪ®з”ЁжҲ·еҗ? 
                  :prefix-icon="User"
                />
              </el-form-item>
              <el-form-item>
                <el-input
                  v-model="registerForm.password"
                  type="password"
                  placeholder="и®ҫзҪ®еҜҶз Ғпј?-32дҪҚпјҢеҗ«еӨ§е°ҸеҶҷеӯ—жҜҚ+ж•°еӯ—пј?
                  :prefix-icon="Lock"
                  show-password
                />
              </el-form-item>
              <el-form-item>
                <el-input
                  v-model="registerForm.confirmPassword"
                  type="password"
                  placeholder="зЎ®и®ӨеҜҶз Ғ"
                  :prefix-icon="Lock"
                  show-password
                />
              </el-form-item>
              <el-form-item>
                <el-input 
                  v-model="registerForm.email" 
                  type="email" 
                  placeholder="йӮ®з®ұең°еқҖпјҲеҸҜйҖүпјү"
                  :prefix-icon="Message"
                />
              </el-form-item>
              <div class="form-actions">
                <el-button 
                  type="success" 
                  :loading="loading" 
                  class="action-btn"
                  @click="onRegister"
                >
                  жі?еҶ?
                </el-button>
              </div>
            </el-form>
          </el-tab-pane>

          <el-tab-pane label="з®ЎзҗҶе‘? name="admin">
            <div class="admin-warning">
              <el-icon><Warning /></el-icon>
              <span>д»…йҷҗзі»з»ҹз®ЎзҗҶе‘ҳи®ҝй—?/span>
            </div>
            <el-form :model="adminForm" class="login-form" size="large" @submit.prevent>
              <el-form-item>
                <el-input 
                  v-model="adminForm.username" 
                  placeholder="з®ЎзҗҶе‘ҳиҙҰеҸ? 
                  :prefix-icon="UserFilled"
                />
              </el-form-item>
              <el-form-item>
                <el-input
                  v-model="adminForm.password"
                  type="password"
                  placeholder="з®ЎзҗҶе‘ҳеҜҶз ?
                  :prefix-icon="Lock"
                  show-password
                  @keyup.enter="onAdminLogin"
                />
              </el-form-item>
              <div class="form-actions">
                <el-button 
                  type="danger" 
                  :loading="loading" 
                  class="action-btn"
                  @click="onAdminLogin"
                >
                  з®ЎзҗҶе‘ҳзҷ»еҪ?
                </el-button>
              </div>
            </el-form>
          </el-tab-pane>
        </el-tabs>
      </el-card>

      <div class="login-footer">
        <p>В© 2024 Security File Manager. All Rights Reserved.</p>
      </div>
    </div>

    <el-dialog v-model="forgotVisible" title="жүҫеӣһеҜҶз Ғ" width="420px" :close-on-click-modal="false" @closed="onCloseForgot">
      <el-steps :active="forgotStep" simple finish-status="success">
        <el-step title="йӮ®з®ұж ЎйӘҢ" />
        <el-step title="йӘҢиҜҒз ? />
        <el-step title="йҮҚзҪ®еҜҶз Ғ" />
      </el-steps>

      <div class="forgot-body" v-if="forgotStep === 1">
        <el-form :model="forgotForm" label-position="top">
          <el-form-item label="з”ЁжҲ·еҗ?>
            <el-input v-model="forgotForm.username" placeholder="иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚ" />
          </el-form-item>
          <el-form-item label="йӮ®з®ұ">
            <el-input v-model="forgotForm.email" placeholder="иҜ·иҫ“е…ҘжіЁеҶҢйӮ®з®? />
          </el-form-item>
        </el-form>
      </div>

      <div class="forgot-body" v-else-if="forgotStep === 2">
        <el-form :model="forgotForm" label-position="top">
          <el-form-item label="йӘҢиҜҒз ?>
            <el-input v-model="forgotForm.code" placeholder="иҜ·иҫ“е…?дҪҚйӘҢиҜҒз Ғ" maxlength="6" />
          </el-form-item>
        </el-form>
        <div class="code-actions">
          <el-button :disabled="codeCooldown > 0" @click="onSendResetCode">
            {{ codeCooldown > 0 ? `йҮҚж–°еҸ‘йҖ?${codeCooldown}s)` : 'йҮҚж–°еҸ‘йҖҒйӘҢиҜҒз Ғ' }}
          </el-button>
        </div>
      </div>

      <div class="forgot-body" v-else>
        <el-form :model="forgotForm" label-position="top">
          <el-form-item label="ж–°еҜҶз ?>
            <el-input v-model="forgotForm.newPassword" type="password" show-password placeholder="8-32дҪҚпјҢеҗ«еӨ§е°ҸеҶҷеӯ—жҜҚ+ж•°еӯ—" />
          </el-form-item>
          <el-form-item label="зЎ®и®Өж–°еҜҶз ?>
            <el-input v-model="forgotForm.confirmPassword" type="password" show-password placeholder="еҶҚж¬Ўиҫ“е…Ҙж–°еҜҶз ? />
          </el-form-item>
        </el-form>
      </div>

      <template #footer>
        <el-button @click="onCloseForgot">еҸ–ж¶Ҳ</el-button>
        <el-button v-if="forgotStep === 1" type="primary" :loading="forgotLoading" @click="onSendResetCode">еҸ‘йҖҒйӘҢиҜҒз Ғ</el-button>
        <el-button v-else-if="forgotStep === 2" type="primary" :loading="forgotLoading" @click="onVerifyResetCode">йӘҢиҜҒ</el-button>
        <el-button v-else type="primary" :loading="forgotLoading" @click="onConfirmReset">йҮҚзҪ®еҜҶз Ғ</el-button>
      </template>
    </el-dialog>
  </div>
</template>



<script setup>
import { ref } from "vue";
import { useRouter } from "vue-router";
import { ElMessage } from "element-plus";
import { User, Lock, Message, UserFilled, Files, Warning } from '@element-plus/icons-vue';
import { login, register, requestPasswordResetCode, verifyPasswordResetCode, confirmPasswordReset } from "../api/auth.js";

const router = useRouter();
const loading = ref(false);
const activeTab = ref("login");
const forgotVisible = ref(false);
const forgotStep = ref(1);
const forgotLoading = ref(false);
const codeCooldown = ref(0);
let codeTimer = null;

const loginForm = ref({
  username: "",
  password: "",
});

const adminForm = ref({
  username: "",
  password: "",
});

const registerForm = ref({
  username: "",
  password: "",
  confirmPassword: "",
  email: "",
});

const forgotForm = ref({
  username: "",
  email: "",
  code: "",
  newPassword: "",
  confirmPassword: "",
});

const onLogin = async () => {
  if (!loginForm.value.username || !loginForm.value.password) {
    ElMessage.warning("иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚе’ҢеҜҶз ?);
    return;
  }
  loading.value = true;
  try {
    const res = await login(loginForm.value);
    const payload = res?.data;
    if (!payload || payload.code !== 200) {
      ElMessage.error(payload?.message || "зҷ»еҪ•еӨұиҙҘ");
      return;
    }
    const data = payload?.data;
    const token = data?.token;
    const role = data?.role;
    if (!token) {
      ElMessage.error("зҷ»еҪ•еӨұиҙҘпјҡжңӘиҺ·еҸ–еҲ?token");
      return;
    }
    localStorage.setItem("token", token);
    localStorage.setItem("role", role || "user");
    localStorage.setItem("username", data?.username || "");
    localStorage.setItem("userId", data?.userId ?? "");
    
    router.push("/files");
  } catch (e) {
    // й”ҷиҜҜе·Із”ұжӢҰжҲӘеҷЁжҸҗзӨ?
  } finally {
    loading.value = false;
  }
};

const onAdminLogin = async () => {
  if (!adminForm.value.username || !adminForm.value.password) {
    ElMessage.warning("иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚе’ҢеҜҶз ?);
    return;
  }
  loading.value = true;
  try {
    const res = await login(adminForm.value);
    const payload = res?.data;
    if (!payload || payload.code !== 200) {
      ElMessage.error(payload?.message || "зҷ»еҪ•еӨұиҙҘ");
      return;
    }
    const data = payload?.data;
    const token = data?.token;
    const role = data?.role;
    if (!token) {
      ElMessage.error("зҷ»еҪ•еӨұиҙҘпјҡжңӘиҺ·еҸ–еҲ?token");
      return;
    }
    
    // жЈҖжҹҘжҳҜеҗҰжҳҜз®ЎзҗҶе‘?
    if (role !== "admin") {
      ElMessage.error("йқһз®ЎзҗҶе‘ҳиҙҰеҸ·пјҢиҜ·дҪҝз”Ёжҷ®йҖҡзҷ»еҪ?);
      return;
    }
    
    localStorage.setItem("token", token);
    localStorage.setItem("role", role);
    localStorage.setItem("username", data?.username || "");
    localStorage.setItem("userId", data?.userId ?? "");
    router.push("/admin");
  } catch (e) {
    // й”ҷиҜҜе·Із”ұжӢҰжҲӘеҷЁжҸҗзӨ?
  } finally {
    loading.value = false;
  }
};

const onRegister = async () => {
  const { username, password, confirmPassword, email } = registerForm.value;
  
  if (!username || !password) {
    ElMessage.warning("иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚе’ҢеҜҶз ?);
    return;
  }
  
  if (password !== confirmPassword) {
    ElMessage.warning("дёӨж¬Ўиҫ“е…Ҙзҡ„еҜҶз ҒдёҚдёҖиҮ?);
    return;
  }
  
  if (password.length < 8 || password.length > 32) {
    ElMessage.warning("еҜҶз Ғй•ҝеәҰеә”еңЁ8-32дҪҚд№Ӣй—?);
    return;
  }

  const passwordRule = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).+$/;
  if (!passwordRule.test(password)) {
    ElMessage.warning("еҜҶз Ғеҝ…йЎ»еҢ…еҗ«еӨ§еҶҷеӯ—жҜҚгҖҒе°ҸеҶҷеӯ—жҜҚе’Ңж•°еӯ—");
    return;
  }
  
  loading.value = true;
  try {
    const res = await register({ username, password, email });
    const payload = res?.data;
    if (!payload || payload.code !== 200) {
      ElMessage.error(payload?.message || "жіЁеҶҢеӨұиҙҘ");
      return;
    }
    ElMessage.success("жіЁеҶҢжҲҗеҠҹпјҢиҜ·зҷ»еҪ•");
    activeTab.value = "login";
    loginForm.value.username = username;
    loginForm.value.password = "";
  } catch (e) {
    // й”ҷиҜҜе·Із”ұжӢҰжҲӘеҷЁжҸҗзӨ?
  } finally {
    loading.value = false;
  }
};

const openForgot = () => {
  forgotVisible.value = true;
  forgotStep.value = 1;
};

const onCloseForgot = () => {
  forgotVisible.value = false;
  forgotStep.value = 1;
  forgotForm.value = { username: "", email: "", code: "", newPassword: "", confirmPassword: "" };
  if (codeTimer) {
    clearInterval(codeTimer);
    codeTimer = null;
  }
  codeCooldown.value = 0;
};

const startCooldown = (seconds) => {
  codeCooldown.value = seconds;
  if (codeTimer) clearInterval(codeTimer);
  codeTimer = setInterval(() => {
    if (codeCooldown.value <= 1) {
      clearInterval(codeTimer);
      codeTimer = null;
      codeCooldown.value = 0;
    } else {
      codeCooldown.value -= 1;
    }
  }, 1000);
};

const onSendResetCode = async () => {
  const username = forgotForm.value.username?.trim();
  const email = forgotForm.value.email?.trim();
  if (!username || !email) {
    ElMessage.warning("иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚе’ҢйӮ®з®?);
    return;
  }
  const emailRule = /^[\w-]+(\.[\w-]+)*@[\w-]+(\.[\w-]+)+$/;
  if (!emailRule.test(email)) {
    ElMessage.warning("йӮ®з®ұж јејҸдёҚжӯЈзЎ?);
    return;
  }
  forgotLoading.value = true;
  try {
    const res = await requestPasswordResetCode({ username, email });
    const payload = res?.data;
    if (!payload || payload.code !== 200) {
      ElMessage.error(payload?.message || "еҸ‘йҖҒеӨұиҙ?);
      return;
    }
    ElMessage.success("йӘҢиҜҒз Ғе·ІеҸ‘йҖ?);
    forgotStep.value = 2;
    startCooldown(60);
  } catch (e) {
    // й”ҷиҜҜе·Із”ұжӢҰжҲӘеҷЁжҸҗзӨ?
  } finally {
    forgotLoading.value = false;
  }
};

const onVerifyResetCode = async () => {
  const username = forgotForm.value.username?.trim();
  const email = forgotForm.value.email?.trim();
  const code = forgotForm.value.code?.trim();
  if (!username || !email || !code) {
    ElMessage.warning("иҜ·иҫ“е…ҘйӮ®з®ұе’ҢйӘҢиҜҒз ?);
    return;
  }
  if (!/^\d{6}$/.test(code)) {
    ElMessage.warning("йӘҢиҜҒз Ғж јејҸдёҚжӯЈзЎ®");
    return;
  }
  forgotLoading.value = true;
  try {
    const res = await verifyPasswordResetCode({ username, email, code });
    const payload = res?.data;
    if (!payload || payload.code !== 200) {
      ElMessage.error(payload?.message || "йӘҢиҜҒеӨұиҙҘ");
      return;
    }
    ElMessage.success("йӘҢиҜҒйҖҡиҝҮпјҢиҜ·и®ҫзҪ®ж–°еҜҶз ?);
    forgotStep.value = 3;
  } catch (e) {
    // й”ҷиҜҜе·Із”ұжӢҰжҲӘеҷЁжҸҗзӨ?
  } finally {
    forgotLoading.value = false;
  }
};

const onConfirmReset = async () => {
  const username = forgotForm.value.username?.trim();
  const email = forgotForm.value.email?.trim();
  const code = forgotForm.value.code?.trim();
  const newPassword = forgotForm.value.newPassword || '';
  const confirmPassword = forgotForm.value.confirmPassword || '';
  if (!newPassword || !confirmPassword) {
    ElMessage.warning("иҜ·иҫ“е…Ҙж–°еҜҶз Ғ");
    return;
  }
  if (newPassword !== confirmPassword) {
    ElMessage.warning("дёӨж¬Ўиҫ“е…Ҙзҡ„еҜҶз ҒдёҚдёҖиҮ?);
    return;
  }
  if (newPassword.length < 8 || newPassword.length > 32) {
    ElMessage.warning("еҜҶз Ғй•ҝеәҰеә”еңЁ8-32дҪҚд№Ӣй—?);
    return;
  }
  const passwordRule = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).+$/;
  if (!passwordRule.test(newPassword)) {
    ElMessage.warning("еҜҶз Ғеҝ…йЎ»еҢ…еҗ«еӨ§еҶҷеӯ—жҜҚгҖҒе°ҸеҶҷеӯ—жҜҚе’Ңж•°еӯ—");
    return;
  }
  forgotLoading.value = true;
  try {
    const res = await confirmPasswordReset({ username, email, code, newPassword });
    const payload = res?.data;
    if (!payload || payload.code !== 200) {
      ElMessage.error(payload?.message || "йҮҚзҪ®еӨұиҙҘ");
      return;
    }
    ElMessage.success("еҜҶз Ғе·Іжӣҙж–°пјҢиҜ·дҪҝз”Ёж–°еҜҶз Ғзҷ»еҪ•");
    onCloseForgot();
    activeTab.value = "login";
    loginForm.value.username = username;
    loginForm.value.password = "";
  } catch (e) {
    // й”ҷиҜҜе·Із”ұжӢҰжҲӘеҷЁжҸҗзӨ?
  } finally {
    forgotLoading.value = false;
  }
};
</script>

