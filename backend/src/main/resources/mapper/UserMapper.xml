<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.security.filemanager.mapper.UserMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.security.filemanager.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password_hash" property="passwordHash"/>
        <result column="password_salt" property="passwordSalt"/>
        <result column="master_key_encrypted" property="masterKeyEncrypted"/>
        <result column="master_key_iv" property="masterKeyIv"/>
        <result column="email" property="email"/>
        <result column="nickname" property="nickname"/>
        <result column="avatar_path" property="avatarPath"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="status" property="status"/>
        <result column="role" property="role"/>
    </resultMap>
    
    <!-- 根据用户名查询 -->
    <select id="selectByUsername" resultMap="BaseResultMap">
         SELECT id, username, password_hash, password_salt, 
             master_key_encrypted, master_key_iv,
             email, nickname, avatar_path,
             created_at, updated_at, status, role
        FROM t_user
        WHERE username = #{username}
          AND status = 1
    </select>
    
    <!-- 根据用户名查询（包括禁用状态，用于登录时检查） -->
    <select id="selectByUsernameIncludeDisabled" resultMap="BaseResultMap">
         SELECT id, username, password_hash, password_salt, 
             master_key_encrypted, master_key_iv,
             email, nickname, avatar_path,
             created_at, updated_at, status, role
        FROM t_user
        WHERE username = #{username}
    </select>
    
</mapper>
